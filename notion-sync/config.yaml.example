# Notion Integration Token
# Get it from: https://www.notion.so/my-integrations
notion_token: "ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Parent page ID — used to auto-create missing databases
# Get from the page URL: notion.so/<PAGE_ID>
parent_page_id: "31b1500a-4b9d-802a-94bf-ffefbb879371"

# Notion Database IDs
# Leave empty — sync will auto-find or create them
databases:
  claude_skills: ""
  knowledge_base: ""
  specs: ""
  context: ""
  docs: ""

# Source mappings
sources:
  # Claude Skills → claude_skills DB
  claude_skills: "~/.claude/commands"

  # Knowledge Base → knowledge_base DB（logs, skills-spec）
  knowledge_base_dirs:
    - "~/Desktop/doc/logs"
    - "~/Desktop/doc/skills-spec"

  # Specs → specs DB
  specs_dirs:
    - "~/Desktop/doc/specs"

  # Context → context DB
  context_dirs:
    - "~/Desktop/doc/context"

  # Docs → docs DB（CHANGELOG, alias-cheatsheet）
  docs_files:
    - "~/Desktop/doc/alias-cheatsheet.md"
    - "~/Desktop/doc/CHANGELOG.md"
